# ------------------------------------------------------------------------------
# This Next.js app does NOT need to sit next to LoginAPI or PoultryPro on disk.
# You can use a different folder or a different repo — only these URLs matter.
#
# Local testing — one frontend process
#   1. Copy this file to ".env.local" (same folder as package.json)
#   2. Point ADMIN_* / NEXT_PUBLIC_* at where Login + Farm APIs run (any host)
#   3. Run: npm run dev — only the web app starts; APIs run wherever you host them.
# ------------------------------------------------------------------------------

# Farm API (PoultryFarmAPI) — default from launchSettings https profile
# Use host:port only, or full https:// URL
NEXT_PUBLIC_API_BASE_URL=localhost:7190

# Login API (User.Management.API under poultrycore/LoginAPI)
# Use NEXT_PUBLIC_ADMIN_API_URL (or NEXT_PUBLIC_LOGIN_API_URL) for both browser hints and /api/proxy.
# Optional: ADMIN_API_URL on the host only if the server must call a different base URL than NEXT_PUBLIC_*.
# NEXT_PUBLIC_LOGIN_API_URL=https://localhost:7010
NEXT_PUBLIC_ADMIN_API_URL=localhost:7010
#
# CRITICAL (production): Do NOT set these to your Next.js / marketing domain (e.g. https://poultrymaster.com).
# Payments and login proxy to paths like /api/Payments/subscription-tiers on the LOGIN API only.
#
# Custom domain (e.g. usermanagementapi.techretainer.com) must point at the SAME Cloud Run service that
# actually runs User.Management.API. If the domain returns HTML 404 for /api/Payments/subscription-tiers,
# use the real Cloud Run HTTPS URL until DNS is fixed, e.g.:
#   NEXT_PUBLIC_ADMIN_API_URL=poultrymaster-api-git-XXXXX-ew.a.run.app
#   ADMIN_API_URL=https://poultrymaster-api-git-XXXXX-ew.a.run.app
# (No trailing slash. Region/project IDs differ per project.)
#
# Example with a custom domain when it is wired correctly:
#   NEXT_PUBLIC_ADMIN_API_URL=usermanagementapi.techretainer.com
#   ADMIN_API_URL=https://usermanagementapi.techretainer.com

# Server-side proxy (Next /api/proxy/*) — must be full URL with scheme (optional override for Login API)
FARM_API_URL=https://localhost:7190
ADMIN_API_URL=https://localhost:7010

# If you use HTTP only locally, switch to e.g.:
# NEXT_PUBLIC_API_BASE_URL=localhost:5142
# NEXT_PUBLIC_ADMIN_API_URL=localhost:5010
# FARM_API_URL=http://localhost:5142
# ADMIN_API_URL=http://localhost:5010

# Optional — /support mailto address (defaults in app if unset)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# ------------------------------------------------------------------------------
# Google Cloud Run (frontend service poultrymaster-web)
# • Container port: 8080 (gcloud default) — fix YAML/console if it says 300 (wrong).
# • Deploy: gcloud run deploy poultrymaster-web --source "<repo-root>" --region europe-west1 --port 8080 --allow-unauthenticated
# • Env: NEXT_PUBLIC_* URLs only; do not set LOGIN_API_URL (unused by /api/proxy).
# • Never put Paystack secret keys on the web service — only on Login API (User.Management.API).
#
# Example — two backends (replace with your project’s *.run.app URLs, no trailing slash):
#   Login:  NEXT_PUBLIC_ADMIN_API_URL + ADMIN_API_URL
#           e.g. https://poultrymaster-api-git-1024831506678.europe-west1.run.app
#   Farm:   NEXT_PUBLIC_API_BASE_URL + FARM_API_URL
#           e.g. https://poultrymaster-farm-api-git-1024831506678.europe-west1.run.app
# ------------------------------------------------------------------------------
