# ------------------------------------------------------------------------------
# This Next.js app does NOT need to sit next to LoginAPI or PoultryPro on disk.
# You can use a different folder or a different repo — only these URLs matter.
#
# Local testing — one frontend process
#   1. Copy this file to ".env.local" (same folder as package.json)
#   2. Point ADMIN_* / NEXT_PUBLIC_* at where Login + Farm APIs run (any host)
#   3. Run: npm run dev — only the web app starts; APIs run wherever you host them.
# ------------------------------------------------------------------------------

# Farm API (PoultryFarmAPI) — default from launchSettings https profile
# Use host:port only, or full https:// URL
NEXT_PUBLIC_API_BASE_URL=localhost:7190

# Login API (User.Management.API under PoultryPro/LoginAPI)
# NEXT_PUBLIC_* = browser / build; LOGIN_API_URL / ADMIN_API_URL = server proxy (full https URL)
# Optional alias (overrides NEXT_PUBLIC_ADMIN_API_URL for client URL hints if set):
# NEXT_PUBLIC_LOGIN_API_URL=https://localhost:7010
NEXT_PUBLIC_ADMIN_API_URL=localhost:7010
# Optional server-only alias (overrides ADMIN_API_URL if set):
# LOGIN_API_URL=https://localhost:7010

# Server-side proxy (Next /api/proxy/*) — must be full URL with scheme
FARM_API_URL=https://localhost:7190
ADMIN_API_URL=https://localhost:7010

# If you use HTTP only locally, switch to e.g.:
# NEXT_PUBLIC_API_BASE_URL=localhost:5142
# NEXT_PUBLIC_ADMIN_API_URL=localhost:5010
# FARM_API_URL=http://localhost:5142
# ADMIN_API_URL=http://localhost:5010
